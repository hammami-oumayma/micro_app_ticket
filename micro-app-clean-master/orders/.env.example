JWT_KEY=replace_with_a_long_random_secret_key_string
MONGO_URI=mongodb://mongo:27017/orders

# Atlas (remplace la ligne du dessus) :
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/orders?retryWrites=true&w=majority

# Email du compte autorisé à voir /api/orders/admin/stats (même email que à l'inscription)
ADMIN_EMAIL=admin@example.com

# Notifications email (optionnel) — sinon logs si NOTIFY_LOG=true
# DEMO_NOTIFY_EMAIL=you@example.com
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com
# NOTIFY_LOG=true
