# Same JWT_KEY as other services (min ~32 chars recommended).
JWT_KEY=replace_with_a_long_random_secret_key_string

# Cookie JWT : sur HTTPS en production, mettre COOKIE_SECURE=true. Sur http://localhost laisser vide.
# COOKIE_SECURE=true

# Docker Compose : base locale (service "mongo" dans docker-compose.yml)
MONGO_URI=mongodb://mongo:27017/auth

# OU MongoDB Atlas (remplace la ligne ci-dessus) :
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/auth?retryWrites=true&w=majority
